# =============================================================================
# wallet-service — environment variables
# Copy to .env then `make run` (or `source .env && go run ./cmd/server`).
# =============================================================================

APP_ENV=dev
GIN_MODE=debug

# =============================================================================
# TIMEOUTS — full chain when calling an SP, ordered inner → outer (HLD §9).
# Inner timeouts fire first, so customer sees 503/504 quickly, never hangs.
# =============================================================================

# ④ PG row-lock wait (inner ring). Applied per session via AfterConnect SET.
#    Fires when post_withdraw / post_transfer waits > this for a row lock.
DB_LOCK_TIMEOUT=1500ms

# ⑤ PG total statement (SP) execution. Applied per session via AfterConnect SET.
#    Fires when the whole SP takes longer than this (e.g. slow validate).
DB_STATEMENT_TIMEOUT=2500ms

# ② pgx TCP connect timeout. Only relevant on cold connections.
DB_CONNECT_TIMEOUT=5s

# ① Hard per-request ctx deadline (outer ring). Wraps c.Request.Context() in
#    middleware.WithTimeout. Should be >= DB_STATEMENT_TIMEOUT + slack for
#    pgxpool.Acquire wait + PgBouncer queueing.
HTTP_REQUEST_TIMEOUT=10s

# HTTP framework-level timeouts. Apply to whole connection / body upload.
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

# =============================================================================
# HTTP SERVER
# =============================================================================

HTTP_ADDR=:8080

# Interactive API docs (Swagger UI) at /swagger/index.html. Leave on for
# dev/staging; set false in production so the API surface is not enumerable.
SWAGGER_ENABLED=true

# =============================================================================
# DATABASE (points at PgBouncer at :6432, NOT at PG :5432 directly)
# =============================================================================

DB_DSN=postgres://wallet_app:wallet_app_dev@localhost:6432/wallet?sslmode=disable
# Optional read replica for lag-tolerant reads (account/client profile + statement
# list only). Unset → those reads use DB_DSN (primary). Balance-realtime, tx
# detail and ops reads always use DB_DSN.
# DB_READ_DSN=postgres://wallet_app:wallet_app_dev@replica-host:6432/wallet?sslmode=disable
# Optional PII pool (role wallet_pii_ro) for the UNMASKED client read
# (GET /v1/ops/clients/:client_no). Unset → that read uses DB_DSN. In prod point
# this at a wallet_pii_ro connection so wallet_app cannot read raw name/CCCD.
# DB_PII_DSN=postgres://wallet_pii_ro:wallet_pii_ro_dev@localhost:6432/wallet?sslmode=disable
DB_MAX_CONNS=50
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE=5m

# =============================================================================
# OPENTELEMETRY — set OTEL_ENABLED=false for local runs without a collector.
# =============================================================================

OTEL_ENABLED=false
OTEL_SERVICE_NAME=wallet-service
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER_ARG=1.0

# Prometheus scrape endpoint at /metrics + request metrics middleware. On by
# default and independent of OTEL_ENABLED (no collector needed). Set false to
# disable both the middleware and the endpoint.
METRICS_ENABLED=true

# =============================================================================
# WRITE RETRY — server-side retry of RETRYABLE conflicts (40001 / 40P01).
# 0 = no retry (conflict returned to caller as a retryable 409). Raise to 2-3
# to absorb hot-account contention once the conflict rate is understood.
# =============================================================================
DB_TX_MAX_RETRIES=0

# =============================================================================
# END-OF-DAY SCHEDULERS — in-process daily close. Disabled by default; enable on
# exactly ONE replica. EOD_DSN MUST be a DIRECT primary connection (NOT PgBouncer
# :6432) authenticating as wallet_eod — the only role allowed to write the
# tamper-evident trial balance. The procedures are long resumable batches, so the
# EOD pool runs with statement_timeout disabled.
#
# Modern-core split — two fixed-daily-time jobs on the same pool:
#   • CUSTOMER EOD (run_eod) at EOD_RUN_AT, AFTER the midnight roll → closes the
#     PRIOR calendar day (snapshot / prev-day-roll / restraint-expiry).
#   • GL CLOSE (run_gl_close) at EOD_GL_CUTOFF → seals TODAY's accounting day with
#     no ledger downtime (post-cutoff GL entries carry the next accounting date).
# =============================================================================
EOD_ENABLED=false
# EOD_DSN=postgres://wallet_eod:CHANGE_ME@primary-host:5432/wallet?sslmode=require
EOD_RUN_AT=00:30:00
# GL accounting cutoff (modern-core): run_gl_close fires here to SEAL today's
# accounting day with no ledger downtime — post-cutoff GL entries carry the next
# accounting date. MUST equal WLT_GL_CONFIG.cutoff_time.
EOD_GL_CUTOFF=18:00:00
EOD_TIMEZONE=Asia/Ho_Chi_Minh
EOD_RUN_TIMEOUT=30m

# =============================================================================
# WITHDRAWAL SLA-TIMEOUT JANITOR (US-5.3)
# =============================================================================
# Periodically auto-reverses withdrawals stuck past FINAL_DEADLINE (SUBMITTED_AT
# + 24h) via reverse_stuck_withdrawals(). Opt-in; enable on exactly ONE replica
# (overlap is harmless — candidates are taken FOR UPDATE SKIP LOCKED). Runs on
# the ordinary app pool, no dedicated DSN.
WD_JANITOR_ENABLED=false
WD_JANITOR_INTERVAL=15m
WD_JANITOR_BATCH_SIZE=100
WD_JANITOR_RUN_TIMEOUT=60s

# =============================================================================
# PARTITION ROLL-FORWARD JANITOR
# =============================================================================
# Keeps the monthly partitions of the 4 partitioned parents (wlt_tran_hist,
# wlt_outbox, wlt_acct_bal, fm_client_audit_log) created ahead by re-running
# fn_ensure_wallet_partitions(current_month, +N months) on an interval. Without
# it, once the pre-created partitions run out, inserts fall into the DEFAULT
# catch-all partition (bloat) AND adding the missing month is then blocked until
# those rows are moved.
#
# ENABLED BY DEFAULT (unlike EOD / WD janitor). fn_ensure_wallet_partitions is
# idempotent (CREATE … IF NOT EXISTS) and SECURITY DEFINER, so it is safe to run
# on EVERY replica at once — no "exactly one replica" rule, no leader election. It
# runs as wallet_app on the ordinary app pool (single bounded statement). Set
# PARTITION_ROLLER_ENABLED=false only for throwaway/test contexts.
PARTITION_ROLLER_ENABLED=true
PARTITION_ROLLER_INTERVAL=24h
PARTITION_LOOKAHEAD_MONTHS=3
PARTITION_ROLLER_RUN_TIMEOUT=60s

# =============================================================================
# JWT — bearer-token validation + per-route RBAC (US-9.10).
#
# Disabled by default (JWT_ENABLED=false) → middleware is a no-op and the
# service falls back to the X-Caller-Subject / X-Channel headers (dev / staged
# rollout). Enable in staging/prod so this service validates tokens
# independently of the API gateway (defense-in-depth).
#
# Algorithm = HS256 → set JWT_HMAC_SECRET (>=32 random bytes).
# Algorithm = RS256 → set JWT_RSA_PUBLIC_KEY to the PEM-encoded public key
#                     (inline PEM, not a file path).
#
# Roles claim: a JSON array of strings, e.g. ["wallet.finance.reverse"].
# Channel claim: one of MOBILE | OPSUI | TREASURY | PARTNER | API.
# =============================================================================
JWT_ENABLED=false
# JWT_ISSUER=https://gateway.internal/auth
# JWT_AUDIENCE=wallet-service
# JWT_ALGORITHM=HS256
# JWT_HMAC_SECRET=CHANGE_ME_use_at_least_32_random_bytes
# For RS256 instead of HS256:
# JWT_ALGORITHM=RS256
# JWT_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# JWT_ROLES_CLAIM=roles
# JWT_CHANNEL_CLAIM=channel
# JWT_CLOCK_SKEW=30s
