{
  "name": "wallet-outbox-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",

    "database.hostname": "${DB_HOST:-postgres}",
    "database.port": "${DB_PORT:-5432}",
    "database.user": "${DB_USER:-wallet_app}",
    "database.password": "${DB_PASSWORD}",
    "database.dbname": "${DB_NAME:-wallet}",
    "database.server.name": "wallet-db",
    "topic.prefix": "wallet",

    "plugin.name": "pgoutput",
    "table.include.list": "public.wlt_outbox",
    "slot.name": "wallet_outbox_slot",
    "publication.name": "wallet_outbox_publication",
    "publication.autocreate.mode": "filtered",

    "_comment_transforms": "Use Debezium Outbox EventRouter to route each row to its destination topic (WLT_OUTBOX.topic column)",
    "transforms": "outbox",
    "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
    "transforms.outbox.table.field.event.id": "event_uuid",
    "transforms.outbox.table.field.event.key": "partition_key",
    "transforms.outbox.table.field.event.type": "event_type",
    "transforms.outbox.table.field.event.payload": "payload",
    "transforms.outbox.table.field.event.timestamp": "created_at",
    "transforms.outbox.table.fields.additional.placement": "topic:header:topic,headers:header:headers,event_type:header:eventType",
    "transforms.outbox.route.by.field": "topic",
    "transforms.outbox.route.topic.regex": "(.*)",
    "transforms.outbox.route.topic.replacement": "$1",

    "_comment_serialization": "StringConverter for keys (partition_key), JsonConverter for values (payload jsonb)",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": false,

    "_comment_snapshot": "Never snapshot (outbox is append-only; we only want new INSERTs)",
    "snapshot.mode": "never",
    "snapshot.locking.mode": "none",

    "_comment_performance": "Batch settings for throughput",
    "max.batch.size": 1000,
    "max.queue.size": 10000,
    "poll.interval.ms": 500,

    "_comment_reliability": "Skip bad events rather than halt; heartbeat to prevent slot bloat",
    "tombstones.on.delete": false,
    "heartbeat.interval.ms": 30000,
    "heartbeat.topics.prefix": "__debezium-heartbeat",
    "event.processing.failure.handling.mode": "skip",

    "_comment_types": "Handle PostgreSQL types correctly",
    "decimal.handling.mode": "string",
    "binary.handling.mode": "base64",
    "time.precision.mode": "connect",

    "_comment_history": "Schema history for connector restart",
    "schema.history.internal.kafka.bootstrap.servers": "${KAFKA_BROKERS:-kafka:9092}",
    "schema.history.internal.kafka.topic": "schema-changes.wallet-outbox"
  }
}
