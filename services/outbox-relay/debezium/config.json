{
  "name": "wallet-outbox-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "wallet_app",
    "database.password": "wallet_password",
    "database.dbname": "wallet",
    "database.server.name": "wallet-db",
    "topic.prefix": "wallet",
    "plugin.name": "pgoutput",
    "table.include.list": "public.wlt_outbox",
    "column.include.list": "public.wlt_outbox.id,public.wlt_outbox.event_uuid,public.wlt_outbox.event_type,public.wlt_outbox.payload,public.wlt_outbox.created_at,public.wlt_outbox.processed_at,public.wlt_outbox.retry_count",
    "transforms": "unwrap,route",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "true",
    "transforms.unwrap.add.fields": "op,ts_ms",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "([^.]+)\\.([^.]+)\\.([^.]+)",
    "transforms.route.replacement": "$3",
    "transforms.route.topic.prefix": "wallet.",
    "transforms.route.topic.suffix": ".cdc",
    "tombstones.on.delete": "false",
    "snapshot.mode": "schema_only",
    "snapshot.locking.mode": "none",
    "slot.name": "wallet_outbox_slot",
    "publication.name": "wallet_outbox_publication",
    "publication.autocreate.mode": "filtered",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "decimal.handling.mode": "string",
    "binary.handling.mode": "base64",
    "time.precision.mode": "connect",
    "interval.handling.mode": "numeric",
    "database.history.kafka.bootstrap.servers": "kafka:9092",
    "database.history.kafka.topic": "schema-changes.wallet",
    "database.history.skip.unparseable.ddl": "true",
    "database.history.store.only.captured.tables.ddl": "true",
    "database.history.store.only.captured.databases.ddl": "true",
    "max.batch.size": "1000",
    "max.queue.size": "10000",
    "poll.interval.ms": "1000",
    "heartbeat.interval.ms": "30000",
    "heartbeat.topics.prefix": "__debezium-heartbeat",
    "provide.transaction.metadata": "false",
    "event.processing.failure.handling.mode": "skip",
    "max.retry": "3",
    "retry.delay.ms": "5000"
  }
}