# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=wallet_app
DB_PASSWORD=your_password_here
DB_NAME=wallet

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PREFIX=wallet

# Worker Configuration
POLL_INTERVAL=1s
BATCH_SIZE=100
MAX_RETRIES=3
RETRY_DELAY=5s
WORKER_COUNT=4

# Monitoring Configuration
METRICS_PORT=9090

# Logging Configuration
LOG_LEVEL=info