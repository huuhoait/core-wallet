# =============================================================================
# Outbox Relay — Configuration
#
# Two relay modes (switch via RELAY_MODE):
#   polling  — Go workers poll WLT_OUTBOX (simple, no extra infra)
#   cdc      — Debezium CDC via Kafka Connect (low-latency, event-driven)
# =============================================================================

# ── Relay Mode ──────────────────────────────────────────────────────────────
# "polling" (default): Go workers poll DB with FOR UPDATE SKIP LOCKED
# "cdc": Debezium captures WAL changes, relay manages connector + marks SENT
RELAY_MODE=polling

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=wallet_app
DB_PASSWORD=your_password_here
DB_NAME=wallet

# ── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PREFIX=wallet

# ── Polling Mode (RELAY_MODE=polling) ───────────────────────────────────────
POLL_INTERVAL=1s
BATCH_SIZE=100
WORKER_COUNT=4
# MAX_RETRIES: Kafka producer per-send retry budget (sarama Producer.Retry.Max) —
# retries of a single publish inside the broker client before it errors.
MAX_RETRIES=3
# MAX_ATTEMPTS: outbox DEAD threshold — a row is parked DEAD after this many
# failed relay attempts. Combined with the backoff below this sets the retry
# envelope: a FAILED event is retried across that window before going DEAD, so a
# brief Kafka outage does not permanently lose events. With the defaults
# (RETRY_DELAY=5s, RETRY_MAX_DELAY=5m, MAX_ATTEMPTS=10) the window is ~20 minutes.
MAX_ATTEMPTS=10
# Exponential re-claim backoff for FAILED rows: a row waits
# RETRY_DELAY*2^(attempts-1), capped at RETRY_MAX_DELAY, before it is re-claimed.
RETRY_DELAY=5s
RETRY_MAX_DELAY=5m

# ── Lifecycle ───────────────────────────────────────────────────────────────
# Max time to drain in-flight work on SIGINT/SIGTERM before forcing exit.
SHUTDOWN_TIMEOUT=15s

# ── CDC Mode (RELAY_MODE=cdc) ───────────────────────────────────────────────
# Kafka Connect REST endpoint
CDC_CONNECT_URL=http://kafka-connect:8083
# Connector name in Kafka Connect
CDC_CONNECTOR_NAME=wallet-outbox-connector
# Topic Debezium writes CDC events to (used for status tracking)
CDC_TOPIC=wallet.public.wlt_outbox
# Consumer group for the status-tracking consumer
CDC_CONSUMER_GROUP=outbox-relay-cdc
# PG logical replication slot
CDC_SLOT_NAME=wallet_outbox_slot
# PG publication name
CDC_PUBLICATION_NAME=wallet_outbox_publication
# Auto-register the Debezium connector on startup (true/false)
CDC_AUTO_REGISTER=true
# Optional: path to a custom connector config JSON file
# CDC_CONNECTOR_CONFIG=/etc/outbox-relay/debezium-connector.json

# ── Monitoring ──────────────────────────────────────────────────────────────
METRICS_PORT=9090

# ── Tracing (OpenTelemetry) ─────────────────────────────────────────────────
# When enabled, the producer opens a span per published event, continuing the
# trace the posting SP stamped into WLT_OUTBOX.HEADERS->>'traceparent' and
# re-injecting it into the Kafka headers for the downstream consumer. Point this
# at the SAME collector as wallet-service so the trace is one waterfall.
# Disabled by default: the relay still passes the upstream traceparent through.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_SERVICE_NAME=outbox-relay
# Deployment environment label tagged on traces (dev|staging|prod).
ENV=dev

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
