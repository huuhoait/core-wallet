# =============================================================================
# Core Wallet — local dev environment variables
# Copy to .env and adjust for your environment.
#
#   cp .env.example .env
# =============================================================================

# PostgreSQL superuser
POSTGRES_DB=wallet
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev_only
POSTGRES_PORT=5432

# Application roles (created by docker init scripts)
WALLET_APP_PASSWORD=wallet_app_dev
WALLET_PII_RO_PASSWORD=wallet_pii_dev
WALLET_ADMIN_PASSWORD=wallet_admin_dev

# PgBouncer (transaction mode, in front of PG)
PGBOUNCER_PORT=6432

# Adminer (web DB browser, only starts with --profile dev)
ADMINER_PORT=8080
